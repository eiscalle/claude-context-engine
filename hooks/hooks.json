{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "wiki-run \"${CLAUDE_PLUGIN_ROOT}/hooks/session_start.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "wiki-run \"${CLAUDE_PLUGIN_ROOT}/hooks/pre_compact.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "wiki-run \"${CLAUDE_PLUGIN_ROOT}/hooks/session_end.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
