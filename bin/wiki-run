#!/bin/bash
# wiki-run — wrapper that sets up env vars and runs Python scripts via uv.
# Used by hooks and skills. Placed in bin/ so the plugin system adds it to PATH.

# Resolve plugin root from this script's location (bin/ is one level deep)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
export CLAUDE_PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(dirname "$SCRIPT_DIR")}"

export UV_PROJECT_ENVIRONMENT="${CLAUDE_PLUGIN_DATA:-$CLAUDE_PLUGIN_ROOT}/.venv"
exec uv run --no-env-file --project "${CLAUDE_PLUGIN_ROOT}" python "$@"
